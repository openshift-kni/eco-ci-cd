#!/bin/bash
# Check BMC iptables rules on hypervisor
# Generated by Ansible template

FOUND=0
TOTAL={{ spoke_hub_connectivity_bmc_ports | length }}
SOURCE_RANGE="{{ spoke_hub_connectivity_spoke_bmc_ip_range }}"
HV_IP="{{ spoke_hub_connectivity_hv_corporate_ip }}"
HUB_IP="{{ spoke_hub_connectivity_hub_cluster_ip }}"

{% for port in spoke_hub_connectivity_bmc_ports %}
sudo iptables -t nat -C PREROUTING -s ${SOURCE_RANGE} -d ${HV_IP} -p tcp \
  --dport {{ port }} -j DNAT --to-destination ${HUB_IP}:{{ port }} 2>/dev/null \
  && FOUND=$((FOUND + 1))
{% endfor %}

echo "${FOUND}/${TOTAL}"
