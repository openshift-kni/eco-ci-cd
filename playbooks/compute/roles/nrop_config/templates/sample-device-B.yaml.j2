apiVersion: v1
kind: ConfigMap
metadata:
  name: device-b-configmap
  namespace: sample-dev-ns
data:
  example_com_deviceB.yaml: |
      devicename: example.com/deviceB
      devices:
        '*':
          - id: DevB1
            healthy: true
            numanode: 0
          - id: DevB2
            healthy: true
            numanode: 0
          - id: DevB3
            healthy: true
            numanode: 0
          - id: DevB4
            healthy: true
            numanode: 0
          - id: DevB5
            healthy: true
            numanode: 0
          - id: DevB6
            healthy: true
            numanode: 0
          - id: DevB7
            healthy: true
            numanode: 0
          - id: DevB8
            healthy: true
            numanode: 0
          - id: DevB9
            healthy: true
            numanode: 0
          - id: DevB10
            healthy: true
            numanode: 0
          - id: DevB11
            healthy: true
            numanode: 1
          - id: DevB12
            healthy: true
            numanode: 1
          - id: DevB13
            healthy: true
            numanode: 1
          - id: DevB14
            healthy: true
            numanode: 1
          - id: DevB15
            healthy: true
            numanode: 1
          - id: DevB16
            healthy: true
            numanode: 1
          - id: DevB17
            healthy: true
            numanode: 1
          - id: DevB18
            healthy: true
            numanode: 1
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: device-plugin-b-ds
  namespace: sample-dev-ns
spec:
  selector:
      matchLabels:
        name: device-plugin-b
  template:
    metadata:
      labels:
        name: device-plugin-b
    spec:
      serviceAccountName: sampledevices-sa
      containers:
      - name: device-plugin-b-container
        securityContext:
          privileged: true
        image: {{ device_plugin_image }}
        imagePullPolicy: IfNotPresent
        env:
        - name: DEVICE_RESOURCE_NAME
          value: "example.com/deviceB"
        command:
          - /bin/deviceplugin
        args:
          - --alsologtostderr
          - --config-dir=/etc/devices
        volumeMounts:
        - name: kubeletsockets
          mountPath: /var/lib/kubelet/device-plugins
        - name: device-b-config-vol
          mountPath: /etc/devices
      volumes:
      - name: kubeletsockets
        hostPath:
          path: /var/lib/kubelet/device-plugins
          type: Directory
      - configMap:
          name: device-b-configmap
        name: device-b-config-vol
