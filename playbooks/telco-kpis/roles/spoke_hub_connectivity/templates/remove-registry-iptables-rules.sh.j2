#!/bin/bash
# Remove registry iptables rules on hypervisor
# Generated by Ansible template

set -e

SOURCE_RANGE="{{ spoke_hub_connectivity_spoke_cluster_ip_range }}"
HV_IP="{{ spoke_hub_connectivity_hv_corporate_ip }}"
BASTION_IP="{{ spoke_hub_connectivity_hub_bastion_ip }}"
PORT="{{ item }}"

sudo iptables -t nat -D PREROUTING -s ${SOURCE_RANGE} -d ${HV_IP} -p tcp \
  --dport ${PORT} -j DNAT --to-destination ${BASTION_IP}:${PORT} 2>/dev/null \
  && echo "✓ Removed DNAT" || true
sudo iptables -t nat -D POSTROUTING -s ${SOURCE_RANGE} -d ${BASTION_IP} -p tcp \
  --dport ${PORT} -j MASQUERADE 2>/dev/null \
  && echo "✓ Removed MASQUERADE" || true
sudo iptables -D FORWARD -s ${SOURCE_RANGE} -d ${BASTION_IP} -p tcp --dport ${PORT} -j ACCEPT 2>/dev/null && echo "✓ Removed FORWARD" || true
