#!/bin/bash
################################################################################
# Script: run-cpu_util-test.sh
# Purpose: Execute CPU utilization test inside telco-kpis-test-runner container
# Generated from: playbooks/telco-kpis/templates/run-cpu_util-test.sh.j2
#
# Description:
#   This script runs the CPU utilization test to measure CPU usage under load
#   on isolated CPUs configured with PerformanceProfile. It clones required
#   repositories, sets up the test environment, executes the test, and
#   captures results.
#
# Environment Variables (set by container/playbook):
#   KUBECONFIG           - Path to kubeconfig file
#   GIT_SSL_NO_VERIFY    - Disable SSL verification for git operations
#   RAN_METRICS_URL      - Pushgateway URL for metrics
#   WORKSPACE            - Working directory for test execution
#   SCRIPTS_DIR          - Directory containing test scripts
#
# Artifacts:
#   Test results are written to /workspace/artifacts/ which is mounted
#   from the bastion host's artifacts directory.
#
################################################################################

set -e

# Copy kubeconfig to writable location (mounted as read-only)
cp /tmp/kubeconfig-ro /tmp/kubeconfig
export KUBECONFIG=/tmp/kubeconfig

# Configure git and metrics
export GIT_SSL_NO_VERIFY=true
export RAN_METRICS_URL=https://pushgateway.ran-metrics.telco5g.corp.redhat.com/metrics/job/pipeline1/

# Clone ran-integration repository
echo "Cloning ran-integration repository..."
git clone --depth 1 {{ telco_kpis_ran_integration_repo | default('https://gitlab.cee.redhat.com/ran/ran-integration.git') }} /workspace/ran-integration
cd /workspace/ran-integration

# Clone cnf-gotests repository
echo "Cloning cnf-gotests repository..."
git clone --depth 1 {{ telco_kpis_cnf_gotests_repo | default('https://gitlab.cee.redhat.com/cnf/cnf-gotests.git') }} cnf-gotests

# Set up environment
export WORKSPACE=/workspace/ran-integration
export SCRIPTS_DIR=/workspace/ran-integration/scripts

# Create artifacts symlink for test output
echo "Creating artifacts symlink..."
ln -sfn /workspace/artifacts /workspace/ran-integration/artifacts

# Execute CPU utilization test
echo "Starting CPU utilization test (duration={{ duration | default(telco_kpis_default_duration_cpu_util) }}{{ baseline_suffix }})..."
set +e
bash scripts/test_cpu_util.sh cpu_util={{ duration | default(telco_kpis_default_duration_cpu_util) }}{{ baseline_suffix }}
exit_code=$?

echo "CPU utilization test completed with exit code: $exit_code"
exit $exit_code
