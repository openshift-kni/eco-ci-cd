#!/bin/bash
# Update Provisioning CR with externalIPs
# Generated by Ansible template

set -e

HV_IP="{{ spoke_hub_connectivity_hv_corporate_ip }}"

# Patch Provisioning CR to enable virtualMediaViaExternalNetwork and set externalIPs
oc --kubeconfig {{ spoke_hub_connectivity_hub_kubeconfig }} patch provisioning provisioning-configuration --type=merge -p '{
  "spec": {
    "virtualMediaViaExternalNetwork": true,
    "externalIPs": ["'"${HV_IP}"'"]
  }
}'

echo "✓ Provisioning CR updated with virtualMediaViaExternalNetwork=true"
echo "✓ Provisioning CR updated with externalIPs=[\"${HV_IP}\"]"
echo ""
echo "NOTE: metal3 pod must be restarted to apply externalIPs configuration"
echo "      oc delete pod -n openshift-machine-api -l baremetal.openshift.io/cluster-baremetal-operator=metal3-state"
