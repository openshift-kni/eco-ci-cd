#!/bin/bash
# Check registry iptables rules on hypervisor
# Generated by Ansible template

FOUND=0
TOTAL={{ spoke_hub_connectivity_cluster_registry_ports | length }}
SOURCE_RANGE="{{ spoke_hub_connectivity_spoke_cluster_ip_range }}"
HV_IP="{{ spoke_hub_connectivity_hv_corporate_ip }}"
BASTION_IP="{{ spoke_hub_connectivity_hub_bastion_ip }}"

{% for port in spoke_hub_connectivity_cluster_registry_ports %}
sudo iptables -t nat -C PREROUTING -s ${SOURCE_RANGE} -d ${HV_IP} -p tcp \
  --dport {{ port }} -j DNAT --to-destination ${BASTION_IP}:{{ port }} 2>/dev/null \
  && FOUND=$((FOUND + 1))
{% endfor %}

echo "${FOUND}/${TOTAL}"
