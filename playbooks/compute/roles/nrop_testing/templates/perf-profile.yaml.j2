apiVersion: performance.openshift.io/v2
kind: PerformanceProfile
metadata:
  name: performance
spec:
  additionalKernelArgs:
  - nmi_watchdog=0
  - audit=0
  - mce=off
  - processor.max_cstate=1
  - idle=poll
  - intel_idle.max_cstate=0
  cpu:
    isolated: 1-3
    reserved: "0"
  hugepages:
    defaultHugepagesSize: 1G
    pages:
    - count: 2
      node: 0
      size: 1G
    - count: 256
      size: 2M
      node: 0
    - count: 4
      node: 1
      size: 1G
    - count: 128
      size: 2M
      node: 1
  nodeSelector:
    node-role.kubernetes.io/{{ nrop_target_pool }}: ""
  numa:
    topologyPolicy: single-numa-node
  realTimeKernel:
    enabled: true
