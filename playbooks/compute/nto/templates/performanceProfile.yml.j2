{#
  Ansible Jinja2 Template for CPU Core Allocation (PerformanceProfile)
  Input variable: cpu_cores (integer, total number of CPU cores)
  Uses namespace for robust list building and within the macro.
#}

{%- macro format_ranges(cores_list) -%}
    {# Initialize namespace for all mutable state within the macro #}
    {%- set ns = namespace(new_ranges=[]) -%}
    {%- if cores_list -%}
        {%- set sorted_cores = cores_list | sort -%}
        {# Initialize start_range and end_range on the namespace object #}
        {%- set ns.start_range = sorted_cores[0] -%}
        {%- set ns.end_range = sorted_cores[0] -%}

        {%- for i in range(1, sorted_cores | length) -%}
            {%- if sorted_cores[i] == ns.end_range + 1 -%}
                {%- set ns.end_range = sorted_cores[i] -%} {# Update ns.end_range #}
            {%- else -%}
                {%- if ns.start_range == ns.end_range -%}
                    {%- set ns.new_ranges = ns.new_ranges + [ns.start_range | string] -%}
                {%- else -%}
                    {%- set ns.new_ranges = ns.new_ranges + [ns.start_range | string ~ '-' ~ ns.end_range | string] -%}
                {%- endif -%}
                {%- set ns.start_range = sorted_cores[i] -%} {# Update ns.start_range #}
                {%- set ns.end_range = sorted_cores[i] -%}   {# Update ns.end_range #}
            {%- endif -%}
        {%- endfor -%}

        {# After loop, handle the last range using values from ns #}
        {%- if ns.start_range == ns.end_range -%}
            {%- set ns.new_ranges = ns.new_ranges + [ns.start_range | string] -%}
        {%- else -%}
            {%- set ns.new_ranges = ns.new_ranges + [ns.start_range | string ~ '-' ~ ns.end_range | string] -%}
        {%- endif -%}
    {%- endif -%}
    {{- ns.new_ranges | join(',') -}}
{%- endmacro -%}

{%- set total_cpu_cores = cpu_cores | int -%}
{%- set all_cpus = range(total_cpu_cores) | list -%}

{%- if total_cpu_cores < 1 -%}
    {{ exceptions.fail("cpu_cores must be 1 or greater.") }}
{%- endif -%}

{# Use namespace for lists that are built iteratively #}
{%- set ns_lists = namespace(reserved_internal=[0], isolated=[]) -%}

{%- if total_cpu_cores < 6 -%}
    {# Simplified logic for very few CPUs. #}
    {%- if total_cpu_cores > 1 -%}
        {%- set ns_lists.reserved_internal = ns_lists.reserved_internal + [total_cpu_cores - 1] -%}
    {%- endif -%}
    {%- set reserved_cores_list = ns_lists.reserved_internal | sort | unique | list -%}
{%- else -%}
    {# Pattern for 6 or more CPUs #}
    {%- set mid = total_cpu_cores // 2 -%}
    {%- set reserved_cores_list = [
        0,
        2,
        mid - 1,
        mid,
        mid + 2,
        total_cpu_cores - 1
    ] | sort | unique | list -%}
{%- endif -%}

{%- for cpu_idx in all_cpus -%}
    {%- if cpu_idx not in reserved_cores_list -%}
        {%- set ns_lists.isolated = ns_lists.isolated + [cpu_idx] -%}
    {%- endif -%}
{%- endfor -%}

apiVersion: performance.openshift.io/v2
kind: PerformanceProfile
metadata:
    name: performance
spec:
    cpu:
        isolated: "{{ format_ranges(ns_lists.isolated) | string }}"
        reserved: "{{ format_ranges(reserved_cores_list) | string }}"
    hugepages:
        defaultHugepagesSize: 1G
        pages:
        - count: 1
          node: 0
          size: 1G
        - count: 128
          node: 1
          size: 2M
    machineConfigPoolSelector:
        machineconfiguration.openshift.io/role: worker-cnf
    net:
        userLevelNetworking: true
    nodeSelector:
        node-role.kubernetes.io/worker-cnf: ""
    numa:
        topologyPolicy: single-numa-node
    realTimeKernel:
        enabled: false
    workloadHints:
        highPowerConsumption: true
        perPodPowerManagement: false
        realTime: true