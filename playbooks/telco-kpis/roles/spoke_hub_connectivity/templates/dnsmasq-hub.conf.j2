# dnsmasq configuration for {{ spoke_hub_connectivity_hub_name }}
# Generated by spoke_hub_connectivity role
# Spoke: {{ spoke_hub_connectivity_spoke_name }}

# Resolve hub wildcard domains to hypervisor external IP for iptables DNAT
# This allows spoke nodes to reach hub services through the hypervisor
address=/apps.{{ spoke_hub_connectivity_hub_name }}.telco-kpis.rdu3.redhat.com/{{ spoke_hub_connectivity_hv_corporate_ip }}
address=/api.{{ spoke_hub_connectivity_hub_name }}.telco-kpis.rdu3.redhat.com/{{ spoke_hub_connectivity_hv_corporate_ip }}

# Disconnected registry on hub bastion (accessed via iptables DNAT)
address=/disconnected.registry.local/{{ spoke_hub_connectivity_hv_corporate_ip }}

# Note: These entries override any upstream DNS responses (including 172.16.x.y)
# Traffic flows: Spoke → HV IP → iptables DNAT → Hub Bastion/Cluster IP
